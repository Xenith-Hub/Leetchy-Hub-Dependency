local function resolveIconName(name)
    if not name or name == "" then return nil end
    name = string.lower(tostring(name)):gsub("_", "-")
    return IconAlias[name:gsub("-", "_")] or name
end

local function applyIcon(imgLabel, name, size)
    if not imgLabel then return end
    local resolved = resolveIconName(name)
    if not resolved then return end
    if Lucide then
        local ok, asset = pcall(Lucide.GetAsset, resolved, size or 48)
        if ok and asset then
            imgLabel.Image           = asset.Url
            imgLabel.ImageRectOffset = asset.ImageRectOffset
            imgLabel.ImageRectSize   = asset.ImageRectSize
            return true
        end
    end
    -- Fallback : flat id, no rect
    local fb = FallbackIcons[resolved] or FallbackIcons[name and name:lower() or ""] or FallbackIcons.dot
    imgLabel.Image           = fb or ""
    imgLabel.ImageRectOffset = Vector2.zero
    imgLabel.ImageRectSize   = Vector2.zero
end

-- Legacy shim retained for callsites that still expect an asset
-- url string ( pre-Lucide ) - returns the fallback id only.
local function iconAsset(name)
    if not name then return nil end
    local r = resolveIconName(name)
    return FallbackIcons[r or ""] or FallbackIcons.dot
end

-- ============================================================
--  TWEEN PRESETS
-- ============================================================
local TI_FAST = TweenInfo.new(0.12, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
local TI_MED  = TweenInfo.new(0.20, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
local TI_SLOW = TweenInfo.new(0.34, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)

local function tween(inst, info, props)
    local t = TweenService:Create(inst, info, props)
    t:Play()
    return t
end

-- ============================================================
--  REGISTRY — lets us re-skin every Instance live when the user
--  edits Library.Scheme then calls UpdateColorsUsingRegistry().
--  Each entry is { instance, prop, schemeKey } so a single pass
--  reapplies the new colour without recreating the UI.
-- ============================================================
local Registry = {}
local function register(inst, prop, schemeKey)
    Registry[#Registry + 1] = { inst = inst, prop = prop, key = schemeKey }
    pcall(function() inst[prop] = Scheme[schemeKey] end)
end

-- ============================================================
--  DOM HELPERS — verbose builders that keep element creation
--  declarative. Every helper returns the new instance so callers
--  can chain children easily.
-- ============================================================
local function corner(parent, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius or 6)
    c.Parent = parent
    return c
end

local function stroke(parent, color, thickness, transparency)
    local s = Instance.new("UIStroke")
    s.Color = color or Scheme.OutlineColor
    s.Thickness = thickness or 1
    s.Transparency = transparency or 0
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent = parent
    return s
end

local function padding(parent, all)
    local p = Instance.new("UIPadding")
    if type(all) == "number" then
        p.PaddingTop    = UDim.new(0, all)
        p.PaddingBottom = UDim.new(0, all)
        p.PaddingLeft   = UDim.new(0, all)
        p.PaddingRight  = UDim.new(0, all)
    elseif type(all) == "table" then
        p.PaddingTop    = UDim.new(0, all.t or 0)
        p.PaddingBottom = UDim.new(0, all.b or 0)
        p.PaddingLeft   = UDim.new(0, all.l or 0)
        p.PaddingRight  = UDim.new(0, all.r or 0)
    end
    p.Parent = parent
    return p
end

local function listLayout(parent, spacing, fill, dir)
    local l = Instance.new("UIListLayout")
    l.Padding = UDim.new(0, spacing or 6)
    l.FillDirection = dir or Enum.FillDirection.Vertical
    l.SortOrder = Enum.SortOrder.LayoutOrder
    l.HorizontalAlignment = fill and Enum.HorizontalAlignment.Left or Enum.HorizontalAlignment.Left
    l.VerticalAlignment = Enum.VerticalAlignment.Top
    l.Parent = parent
    return l
end

local function newFrame(name, parent, props)
    local f = Instance.new("Frame")
    f.Name = name
    f.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    f.BorderSizePixel = 0
    f.Parent = parent
    if props then
        for k, v in pairs(props) do f[k] = v end
    end
    return f
end

local function newLabel(parent, text, size, color, font, align)
    local l = Instance.new("TextLabel")
    l.BackgroundTransparency = 1
    l.Text = text or ""
    l.TextSize = size or 14
    l.TextColor3 = color or Scheme.FontColor
    l.Font = font or Enum.Font.GothamMedium
    l.TextXAlignment = align or Enum.TextXAlignment.Left
    l.TextYAlignment = Enum.TextYAlignment.Center
    l.Size = UDim2.new(1, 0, 1, 0)
    l.Parent = parent
    return l
end

