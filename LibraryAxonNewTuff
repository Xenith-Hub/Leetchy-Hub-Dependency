-- ============================================================
--  AXONHUB LOGO RESOLVER
--  Roblox moderation gates new asset uploads behind a 24h+
--  approval delay, which means rbxassetid:// loads return
--  nothing during that window. getcustomasset() bypasses
--  moderation entirely : we download the PNG once over HTTP,
--  cache it in the executor workspace, and load it as a local
--  texture on every subsequent run. Falls back to the asset id
--  ( still moderated ) and finally to the "A" letter glyph
--  drawn by the caller when neither path produces an image.
-- ============================================================
local AXONHUB_LOGO_LOCAL = "axonhub_logo.png"
local AXONHUB_LOGO_URL   = "https://cdn.discordapp.com/attachments/1498401165065453598/1505246797151473717/image-removebg-preview6.png?ex=6a09edd2&is=6a089c52&hm=407a08f84d8669c197fab4307bf5eeb2416f679e72246fb45ae3c5de2edf7e1c&"
local AXONHUB_LOGO_FALLBACK_ASSET = "rbxassetid://116597186532041"

local function _httpFetch(url)
    -- Try the executor's request() / http_request() / syn.request first.
    local req
    if type(request) == "function" then
        req = request
    elseif type(http_request) == "function" then
        req = http_request
    elseif type(syn) == "table" and type(syn.request) == "function" then
        req = syn.request
    elseif type(fluxus) == "table" and type(fluxus.request) == "function" then
        req = fluxus.request
    end
    if req then
        local ok, res = pcall(req, { Url = url, Method = "GET" })
        if ok and res and (res.StatusCode == 200 or res.Status == 200) and res.Body then
            return res.Body
        end
    end
    -- Fallback : game:HttpGet ( works in some executors ).
    local ok, body = pcall(function() return game:HttpGet(url) end)
    if ok and type(body) == "string" and #body > 0 then return body end
    return nil
end

local _axonLogoResolved
local function resolveAxonLogo()
    if _axonLogoResolved ~= nil then return _axonLogoResolved end
    local hasIsfile  = type(isfile) == "function"
    local hasWrite   = type(writefile) == "function"
    local hasCustom  = type(getcustomasset) == "function"
    -- Already cached on disk ?
    if hasIsfile and hasCustom and isfile(AXONHUB_LOGO_LOCAL) then
        local ok, url = pcall(getcustomasset, AXONHUB_LOGO_LOCAL)
        if ok and type(url) == "string" and #url > 0 then
            _axonLogoResolved = url
            return url
        end
    end
    -- Need write + getcustomasset to fetch + load.
    if not (hasWrite and hasCustom) then
        _axonLogoResolved = AXONHUB_LOGO_FALLBACK_ASSET
        return _axonLogoResolved
    end
    local body = _httpFetch(AXONHUB_LOGO_URL)
    -- Verify PNG magic bytes ( 89 50 4E 47 ) so we don't cache an
    -- HTML error page when the URL has expired.
    if body and #body > 100 and body:sub(1, 4) == "\137PNG" then
        local saveOk = pcall(writefile, AXONHUB_LOGO_LOCAL, body)
        if saveOk then
            local ok, url = pcall(getcustomasset, AXONHUB_LOGO_LOCAL)
            if ok and type(url) == "string" and #url > 0 then
                _axonLogoResolved = url
                return url
            end
        end
    end
    _axonLogoResolved = AXONHUB_LOGO_FALLBACK_ASSET
    return _axonLogoResolved
end

-- ============================================================
--  PARENT RESOLVER ( prefer CoreGui under executors that allow it,
--  otherwise PlayerGui — wrapped in pcall so it never throws ).
-- ============================================================
local function pickParent()
    local ok, target = pcall(function()
        if gethui then return gethui() end
        return CoreGui
    end)
    if ok and target then
        local probe = Instance.new("Folder")
        local placed
        local ok2 = pcall(function()
            probe.Parent = target
            placed = probe.Parent == target
        end)
        probe:Destroy()
        if ok2 and placed then return target end
    end
    return LocalPlayer:WaitForChild("PlayerGui")
end

