-- ============================================================
--  TOOLTIP  ( PC hover + mobile long-press )
--  Library:BindTooltip(element, text) attaches a tiny floating
--  label that follows the mouse on PC, or fades in after a
--  0.5s touch-hold on mobile then auto-hides 2.5s later. A
--  single tooltip frame is lazy-created under Library._ScreenGui
--  and reused for every binding.
-- ============================================================
local function ensureTooltip(lib)
    if lib._tooltip and lib._tooltip.Parent then
        return lib._tooltip, lib._tooltipLbl
    end
    local sg = lib._ScreenGui
    if not sg then return nil end
    local t = Instance.new("Frame")
    t.Name = "Tooltip"
    t.BackgroundColor3 = Color3.fromRGB(14, 14, 18)
    t.BorderSizePixel = 0
    t.AutomaticSize = Enum.AutomaticSize.XY
    t.ZIndex = 999
    t.Visible = false
    t.Parent = sg
    corner(t, 6)
    local ts = stroke(t, Scheme.OutlineColor, 1, 0.25)
    register(ts, "Color", "OutlineColor")
    padding(t, { l = 10, r = 10, t = 6, b = 6 })

    local lbl = Instance.new("TextLabel")
    lbl.Name = "Lbl"
    lbl.BackgroundTransparency = 1
    lbl.AutomaticSize = Enum.AutomaticSize.XY
    lbl.Font = Enum.Font.Gotham
    lbl.TextSize = 11
    lbl.TextColor3 = Scheme.FontColor
    lbl.Text = ""
    lbl.ZIndex = 1000
    lbl.Parent = t
    register(lbl, "TextColor3", "FontColor")

    lib._tooltip = t
    lib._tooltipLbl = lbl
    return t, lbl
end

function Library:BindTooltip(element, text)
    if not element or type(text) ~= "string" or text == "" then return end
    local GuiService   = game:GetService("GuiService")
    local UserInputSvc = game:GetService("UserInputService")
    local insetTop     = GuiService:GetGuiInset().Y

    local function place(px, py)
        local t = self._tooltip
        if not t then return end
        local sz = t.AbsoluteSize
        local vp = workspace.CurrentCamera.ViewportSize
        local x = math.min(px + 14, vp.X - sz.X - 6)
        local y = math.min(py + 14, vp.Y - sz.Y - 6)
        t.Position = UDim2.fromOffset(math.max(x, 4), math.max(y, 4))
    end
    local function showAt(px, py)
        local t, lbl = ensureTooltip(self)
        if not t then return end
        lbl.Text = text
        t.Visible = true
        place(px, py)
    end
    local function hide()
        if self._tooltip then self._tooltip.Visible = false end
    end

    element.MouseEnter:Connect(function()
        local m = UserInputSvc:GetMouseLocation()
        showAt(m.X, m.Y + insetTop)
    end)
    element.MouseMoved:Connect(function(x, y)
        if self._tooltip and self._tooltip.Visible then
            place(x, y + insetTop)
        end
    end)
    element.MouseLeave:Connect(hide)

    -- Mobile : show after 0.5s touch-hold, auto-hide 2.5s later.
    local holdTask
    element.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            holdTask = task.delay(0.5, function()
                showAt(input.Position.X, input.Position.Y)
                task.delay(2.5, hide)
            end)
        end
    end)
    element.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            if holdTask then task.cancel(holdTask); holdTask = nil end
        end
    end)
end

function Library:OnUnload(cb)
    if type(cb) == "function" then
        table.insert(self._UnloadCBs, cb)
    end
end

function Library:Unload()
    if self.Unloaded then return end
    self.Unloaded = true
    for _, cb in ipairs(self._UnloadCBs) do
        pcall(cb)
    end
    for _, c in ipairs(self._Connections) do
        pcall(function() c:Disconnect() end)
    end
    if self._ScreenGui then
        pcall(function() self._ScreenGui:Destroy() end)
    end
end

-- ============================================================
--  NOTIFICATION SYSTEM
--  Top-right toast stack. Each notification animates in from
--  the right, holds for `duration` seconds, then slides back.
--  Multiple notifications stack vertically with smooth reflow.
-- ============================================================
local NotifContainer
local _notifList = {}

local function ensureNotifLayer()
    if NotifContainer and NotifContainer.Parent then return NotifContainer end
    local sg = Instance.new("ScreenGui")
    sg.Name = "ArvynLib_Notifications"
    sg.IgnoreGuiInset = true
    sg.ResetOnSpawn = false
    sg.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    sg.DisplayOrder = 9999
    sg.Parent = pickParent()

    local holder = newFrame("Holder", sg, {
        AnchorPoint = Vector2.new(1, 0),
        Position = UDim2.new(1, -16, 0, 16),
        Size = UDim2.new(0, 320, 1, -32),
        BackgroundTransparency = 1,
    })
    local layout = listLayout(holder, 8)
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Right
    layout.VerticalAlignment = Enum.VerticalAlignment.Top

    NotifContainer = holder
    return holder
end

function Library:Notify(text, duration)
    duration = duration or 3
    local holder = ensureNotifLayer()
    if not holder then return end

    local card = newFrame("Notif", holder, {
        Size = UDim2.new(1, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundColor3 = Scheme.GroupboxColor,
        BackgroundTransparency = 0.05,
        Position = UDim2.new(1, 16, 0, 0),  -- start off-screen right
    })
    register(card, "BackgroundColor3", "GroupboxColor")
    corner(card, 8)

    -- Left accent bar
    local bar = newFrame("Bar", card, {
        Size = UDim2.new(0, 3, 1, -10),
        Position = UDim2.new(0, 5, 0, 5),
        BackgroundColor3 = Scheme.AccentColor,
    })
    register(bar, "BackgroundColor3", "AccentColor")
    corner(bar, 2)

    -- Text
    local container = newFrame("Container", card, {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -28, 0, 0),
        Position = UDim2.new(0, 16, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
    })
    padding(container, { t = 10, b = 10 })

    local lbl = newLabel(container, text, 14, Scheme.FontColor,
        Enum.Font.GothamMedium, Enum.TextXAlignment.Left)
    lbl.Size = UDim2.new(1, 0, 0, 0)
    lbl.AutomaticSize = Enum.AutomaticSize.Y
    lbl.TextWrapped = true
    register(lbl, "TextColor3", "FontColor")

    -- Slide in
    card.Position = UDim2.new(1, 16, 0, 0)
    tween(card, TI_MED, { Position = UDim2.new(0, 0, 0, 0) })

    table.insert(_notifList, card)

    task.delay(duration, function()
        if not card.Parent then return end
        tween(card, TI_MED, { Position = UDim2.new(1, 16, 0, 0) })
        task.wait(0.22)
        if card.Parent then card:Destroy() end
        for i, n in ipairs(_notifList) do
            if n == card then table.remove(_notifList, i); break end
        end
    end)
end

