--[[
    AxonLib — Custom UI Library (Obsidian drop-in compatible)
    -----------------------------------------------------------
    Aesthetic : "Axon Hub" — categorised left sidebar, top config
    bar, two-column groupbox content, dark-blue palette, smooth
    TweenService animations, lucide icons.

    API parity ( what `Slime RNG UI.lua` already calls ) :
        Library:CreateWindow{ Title, Footer, Center, ... } -> Window
        Library:Notify(text, duration)
        Library:SetWatermark(text)        Library:SetWatermarkVisibility(bool)
        Library:OnUnload(callback)
        Library:Unload()
        Library:UpdateColorsUsingRegistry()
        Library.Scheme, Library.Toggles, Library.Options, Library.KeybindFrame

        Window:AddTab(name, icon, category?)        Tab:AddLeftGroupbox(name)        Tab:AddRightGroupbox(name)
        Groupbox:AddToggle(idx, opts)
        Groupbox:AddSlider(idx, opts)
        Groupbox:AddDropdown(idx, opts)
        Groupbox:AddButton(textOrOpts, callback?)        Groupbox:AddInput(idx, opts)
        Groupbox:AddLabel(text, doesWrap?)        Groupbox:AddDivider()

        Element:OnChanged(cb), :SetValue(v), .Value (read), Label:SetText(s)

    Returns the Library table. ThemeManager / SaveManager stubs are
    exposed under `Library.ThemeManager` / `Library.SaveManager` for
    drop-in usage.
--]]

