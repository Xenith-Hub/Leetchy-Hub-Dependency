-- ============================================================
--  TOGGLE FACTORY
--  Renders a row : [icon? bar][text  ............  switch]
--  Switch is a 36x18 pill with a sliding thumb. Click anywhere
--  on the row toggles. Library.Toggles[idx] holds the public
--  object exposing .Value, :SetValue, :OnChanged.
-- ============================================================
local function buildToggle(parent, idx, opts)
    opts = opts or {}
    local default  = opts.Default == true
    local text     = opts.Text or idx
    local tooltip  = opts.Tooltip
    local callback = opts.Callback

    local row = newFrame("Toggle_" .. idx, parent, {
        Size = UDim2.new(1, 0, 0, 36),
        BackgroundColor3 = Scheme.ElementColor,
        BackgroundTransparency = 0,
    })
    register(row, "BackgroundColor3", "ElementColor")
    corner(row, 7)
    -- Subtle border to give the row definition against the card.
    local rowStroke = stroke(row, Scheme.OutlineColor, 1, 0.7)
    register(rowStroke, "Color", "OutlineColor")

    local btn = newButton(row, {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = "",
    })

    local lbl = newLabel(row, text, 13, Scheme.FontColor,
        Enum.Font.GothamMedium, Enum.TextXAlignment.Left)
    lbl.Position = UDim2.new(0, 12, 0, 0)
    lbl.Size = UDim2.new(1, -56, 1, 0)
    register(lbl, "TextColor3", "FontColor")

    -- Optional more-options dots, only attached when the caller
    -- passes opts.OnConfig. Default toggles stay clean ( the user
    -- explicitly asked to drop the placeholder dots ).
    if type(opts.OnConfig) == "function" then
        local dotsBtn = newButton(row, {
            AnchorPoint = Vector2.new(1, 0.5),
            Position = UDim2.new(1, -52, 0.5, 0),
            Size = UDim2.new(0, 22, 0, 22),
            BackgroundTransparency = 1,
            Text = "",
        })
        local dotsImg = newImage(dotsBtn, "", {
            AnchorPoint = Vector2.new(0.5, 0.5),
            Position = UDim2.new(0.5, 0, 0.5, 0),
            Size = UDim2.new(0, 16, 0, 16),
            ImageColor3 = Scheme.DimColor,
        })
        applyIcon(dotsImg, "more-horizontal", 48)
        register(dotsImg, "ImageColor3", "DimColor")
        dotsBtn.MouseButton1Click:Connect(function() pcall(opts.OnConfig) end)
        lbl.Size = UDim2.new(1, -88, 1, 0)
    end

    -- Pill switch
    local pill = newFrame("Pill", row, {
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, -10, 0.5, 0),
        Size = UDim2.new(0, 32, 0, 18),
        BackgroundColor3 = Scheme.ElementColor,
    })
    register(pill, "BackgroundColor3", "ElementColor")
    corner(pill, 9)
    local pillStroke = stroke(pill, Scheme.OutlineColor, 1, 0.2)
    register(pillStroke, "Color", "OutlineColor")

    local thumb = newFrame("Thumb", pill, {
        Size = UDim2.new(0, 14, 0, 14),
        Position = UDim2.new(0, 2, 0.5, -7),
        BackgroundColor3 = Scheme.DimColor,
    })
    corner(thumb, 7)

    local obj = { Value = default, _changed = {}, _idx = idx }

    local function applyVisual(animated)
        local on = obj.Value
        local info = animated and TI_FAST or TweenInfo.new(0, Enum.EasingStyle.Linear)
        tween(thumb, info, {
            Position = on and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7),
            BackgroundColor3 = on and Color3.fromRGB(255, 255, 255) or Scheme.DimColor,
        })
        tween(pill, info, {
            BackgroundColor3 = on and Scheme.AccentColor or Scheme.ElementColor,
        })
        if on then
            -- Re-register active pill to AccentColor so theme updates flow
            register(pill, "BackgroundColor3", "AccentColor")
        else
            register(pill, "BackgroundColor3", "ElementColor")
        end
    end
    applyVisual(false)

    local function fire()
        for _, cb in ipairs(obj._changed) do
            pcall(cb, obj.Value)
        end
        if callback then pcall(callback, obj.Value) end
    end

    function obj:SetValue(v)
        local nv = v and true or false
        if nv == self.Value then return end
        self.Value = nv
        applyVisual(true)
        fire()
    end

    function obj:OnChanged(cb)
        if type(cb) == "function" then
            table.insert(self._changed, cb)
            pcall(cb, self.Value)
        end
        return self
    end

    btn.MouseButton1Click:Connect(function()
        obj:SetValue(not obj.Value)
    end)

    -- Hover tint on the entire row
    bindHover(row, "BackgroundColor3", "ElementColor", "HoverColor")

    if type(opts.Tooltip) == "string" and opts.Tooltip ~= "" then
        Library:BindTooltip(row, opts.Tooltip)
    end

    Library.Toggles[idx] = obj
    return obj
end

-- ============================================================
--  SLIDER FACTORY
--  Two-row layout : [text   value]  +  [progress bar].
--  Drag the bar OR click anywhere on it to set the value.
--  Snaps to `Rounding` ( 0 = integers, 1 = .1, 2 = .01, etc. )
-- ============================================================
local function buildSlider(parent, idx, opts)
    opts = opts or {}
    local minV = opts.Min or 0
    local maxV = opts.Max or 100
    local rounding = opts.Rounding or 0
    local default = opts.Default or minV
    local suffix = opts.Suffix or ""
    local text = opts.Text or idx
    local callback = opts.Callback

    local row = newFrame("Slider_" .. idx, parent, {
        Size = UDim2.new(1, 0, 0, 50),
        BackgroundColor3 = Scheme.ElementColor,
        BackgroundTransparency = 0,
    })
    register(row, "BackgroundColor3", "ElementColor")
    corner(row, 7)
    local rowStroke = stroke(row, Scheme.OutlineColor, 1, 0.7)
    register(rowStroke, "Color", "OutlineColor")
    padding(row, { l = 14, r = 14, t = 8, b = 10 })

    -- ===== Header : label on the left, current value (bold) + dim
    -- "/ max" hint on the right. RichText keeps the layout tight.
    local lbl = newLabel(row, text, 12, Scheme.SubFontColor,
        Enum.Font.GothamMedium, Enum.TextXAlignment.Left)
    lbl.Size = UDim2.new(0.55, 0, 0, 14)
    lbl.Position = UDim2.new(0, 0, 0, 0)
    register(lbl, "TextColor3", "SubFontColor")

    local function formatVal(v)
        local sep = (suffix ~= "" and suffix:sub(1, 1):match("%S")) and " " or ""
        local cur = tostring(v) .. sep .. suffix
        local maxStr = tostring(maxV) .. sep .. suffix
        return string.format(
            "<font color=\"#FFFFFF\"><b>%s</b></font><font color=\"#6E727C\">  /  %s</font>",
            cur, maxStr
        )
    end
    local valLbl = newLabel(row, "", 12, Scheme.FontColor,
        Enum.Font.GothamMedium, Enum.TextXAlignment.Right)
    valLbl.AnchorPoint = Vector2.new(1, 0)
    valLbl.Position = UDim2.new(1, 0, 0, 0)
    valLbl.Size = UDim2.new(0.45, 0, 0, 14)
    valLbl.RichText = true
    valLbl.Text = formatVal(default)
    register(valLbl, "TextColor3", "FontColor")

    -- ===== Track : full-width 4px pill at the bottom of the row.
    -- A wider invisible hit-area sits on top so the user can grab
    -- the thumb easily even though the track itself is thin.
    local trackHost = newFrame("TrackHost", row, {
        Size     = UDim2.new(1, 0, 0, 18),
        Position = UDim2.new(0, 0, 1, -18),
        BackgroundTransparency = 1,
    })
    local track = newFrame("Track", trackHost, {
        AnchorPoint = Vector2.new(0, 0.5),
        Position    = UDim2.new(0, 0, 0.5, 0),
        Size        = UDim2.new(1, 0, 0, 4),
        BackgroundColor3 = Scheme.BackgroundColor,
        BackgroundTransparency = 0.2,
    })
    register(track, "BackgroundColor3", "BackgroundColor")
    corner(track, 2)
    track.ClipsDescendants = false

    -- Fill : a single solid colour pulled from Scheme.SliderFillColor
    -- so the bar always matches the active theme. Onyx ships with a
    -- light grey for the premium look, custom themes route their
    -- AccentColor here so the fill reads as the theme accent.
    local fill = newFrame("Fill", track, {
        Size = UDim2.new(0, 0, 1, 0),
        BackgroundColor3 = Scheme.SliderFillColor,
    })
    register(fill, "BackgroundColor3", "SliderFillColor")
    corner(fill, 2)

    -- Thumb : 14×14 white circle riding the right edge of the fill,
    -- with a soft glow halo behind it for the premium feel.
    local thumb = Instance.new("Frame")
    thumb.Name = "Thumb"
    thumb.AnchorPoint = Vector2.new(0.5, 0.5)
    thumb.Position = UDim2.new(0, 0, 0.5, 0)
    thumb.Size = UDim2.new(0, 14, 0, 14)
    thumb.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    thumb.BorderSizePixel = 0
    thumb.ZIndex = 5
    thumb.Parent = trackHost
    corner(thumb, 8)
    local thumbStroke = Instance.new("UIStroke")
    thumbStroke.Color = Color3.fromRGB(120, 124, 134)
    thumbStroke.Thickness = 1
    thumbStroke.Transparency = 0.4
    thumbStroke.Parent = thumb

    local thumbHalo = Instance.new("ImageLabel")
    thumbHalo.Name = "Halo"
    thumbHalo.BackgroundTransparency = 1
    thumbHalo.AnchorPoint = Vector2.new(0.5, 0.5)
    thumbHalo.Position = UDim2.new(0.5, 0, 0.5, 0)
    thumbHalo.Size = UDim2.new(0, 32, 0, 32)
    thumbHalo.Image = "rbxassetid://6014261993"   -- soft radial glow
    thumbHalo.ImageColor3 = Color3.fromRGB(255, 255, 255)
    thumbHalo.ImageTransparency = 1   -- hidden until drag
    thumbHalo.ScaleType = Enum.ScaleType.Slice
    thumbHalo.SliceCenter = Rect.new(49, 49, 450, 450)
    thumbHalo.ZIndex = 4
    thumbHalo.Parent = thumb

    local function roundTo(v, r)
        local mult = 10 ^ (r or 0)
        return math.floor(v * mult + 0.5) / mult
    end

    local obj = { Value = default, _changed = {}, _idx = idx }

    local TI_VAL = TweenInfo.new(0.14, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    local function setVisual(v, animated)
        local pct = (v - minV) / math.max(maxV - minV, 1e-9)
        pct = math.clamp(pct, 0, 1)
        local info = animated and TI_VAL or TweenInfo.new(0, Enum.EasingStyle.Linear)
        tween(fill,  info, { Size     = UDim2.new(pct, 0, 1, 0) })
        tween(thumb, info, { Position = UDim2.new(pct, 0, 0.5, 0) })
        valLbl.Text = formatVal(v)
    end
    setVisual(default, false)

    local function setFromAlpha(alpha, fire)
        alpha = math.clamp(alpha, 0, 1)
        local v = roundTo(minV + (maxV - minV) * alpha, rounding)
        if v == obj.Value and not fire then return end
        obj.Value = v
        setVisual(v, true)
        if fire then
            for _, cb in ipairs(obj._changed) do pcall(cb, v) end
            if callback then pcall(callback, v) end
        end
    end

    function obj:SetValue(v)
        v = roundTo(math.clamp(v, minV, maxV), rounding)
        if v == self.Value then return end
        self.Value = v
        setVisual(v, true)
        for _, cb in ipairs(self._changed) do pcall(cb, v) end
        if callback then pcall(callback, v) end
    end

    function obj:OnChanged(cb)
        if type(cb) == "function" then
            table.insert(self._changed, cb)
            pcall(cb, self.Value)
        end
        return self
    end

    -- Drag handling : the whole trackHost ( 18px tall ) is the
    -- hit-area, so the thin 4px visual track is still easy to grab.
    local hit = newButton(trackHost, {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 1, 0),
        Text = "",
    })
    local dragging = false
    local TI_THUMB = TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

    hit.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            -- Keep the thumb at its idle size on click ( the user
            -- explicitly asked for no big / blurry pressed state ).
            -- Only the stroke darkens to signal the press.
            tween(thumbStroke, TI_THUMB, { Transparency = 0.15 })
            local rel = (input.Position.X - track.AbsolutePosition.X) / math.max(track.AbsoluteSize.X, 1)
            setFromAlpha(rel, true)
        end
    end)
    hit.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
            tween(thumbStroke, TI_THUMB, { Transparency = 0.4 })
        end
    end)
    hit.MouseEnter:Connect(function()
        if not dragging then
            tween(thumb, TI_THUMB, { Size = UDim2.new(0, 16, 0, 16) })
        end
    end)
    hit.MouseLeave:Connect(function()
        if not dragging then
            tween(thumb, TI_THUMB, { Size = UDim2.new(0, 14, 0, 14) })
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if not dragging then return end
        if input.UserInputType == Enum.UserInputType.MouseMovement
        or input.UserInputType == Enum.UserInputType.Touch then
            local rel = (input.Position.X - track.AbsolutePosition.X) / math.max(track.AbsoluteSize.X, 1)
            setFromAlpha(rel, true)
        end
    end)

    if type(opts.Tooltip) == "string" and opts.Tooltip ~= "" then
        Library:BindTooltip(row, opts.Tooltip)
    end

    Library.Options[idx] = obj
    return obj
end

-- ============================================================
--  BUTTON FACTORY
--  Solid accent-coloured button. Two call signatures :
--      :AddButton("Text", function() end)
--      :AddButton({ Text = "", Func = function() end, Tooltip? })
-- ============================================================
local function buildButton(parent, arg, cb)
    local opts
    if type(arg) == "table" then
        opts = arg
    else
        opts = { Text = arg, Func = cb }
    end
    local text = opts.Text or "Button"
    local fn = opts.Func or opts.Callback or function() end

    -- Dark-gray button to match the black/gray UI theme. The accent
    -- blue only flashes briefly when pressed, otherwise the button
    -- stays in the ElementColor family ( hover -> HoverColor ).
    local row = newFrame("Button", parent, {
        Size = UDim2.new(1, 0, 0, 34),
        BackgroundColor3 = Scheme.ElementColor,
    })
    register(row, "BackgroundColor3", "ElementColor")
    corner(row, 8)

    local btn = newButton(row, {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 1, 0),
        Text = "",
    })

    local lbl = newLabel(row, text, 13, Scheme.FontColor,
        Enum.Font.GothamBold, Enum.TextXAlignment.Center)
    lbl.Size = UDim2.new(1, 0, 1, 0)
    register(lbl, "TextColor3", "FontColor")

    btn.MouseButton1Click:Connect(function()
        tween(row, TI_FAST, { BackgroundColor3 = Scheme.AccentColor })
        task.delay(0.12, function()
            tween(row, TI_FAST, { BackgroundColor3 = Scheme.ElementColor })
        end)
        pcall(fn)
    end)

    bindHover(row, "BackgroundColor3", "ElementColor", "HoverColor")

    if opts and type(opts.Tooltip) == "string" and opts.Tooltip ~= "" then
        Library:BindTooltip(row, opts.Tooltip)
    end

    return {
        SetText = function(_, t) lbl.Text = tostring(t) end,
    }
end

-- ============================================================
--  LABEL FACTORY ( supports doesWrap + :SetText ).
-- ============================================================
local function buildLabel(parent, text, doesWrap)
    local row = newFrame("Label", parent, {
        Size = UDim2.new(1, 0, 0, doesWrap and 0 or 22),
        BackgroundTransparency = 1,
        AutomaticSize = doesWrap and Enum.AutomaticSize.Y or Enum.AutomaticSize.None,
    })
    local lbl = newLabel(row, text, 12, Scheme.SubFontColor,
        Enum.Font.Gotham, Enum.TextXAlignment.Left)
    lbl.Size = UDim2.new(1, 0, 1, 0)
    if doesWrap then
        lbl.TextWrapped = true
        lbl.AutomaticSize = Enum.AutomaticSize.Y
    end
    register(lbl, "TextColor3", "SubFontColor")
