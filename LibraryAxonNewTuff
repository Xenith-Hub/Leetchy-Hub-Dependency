-- ============================================================
--  GROUPBOX ( title above + rounded element card )
--  Layout matches the Arvyn Hub reference : a small uppercase
--  dim label sits OUTSIDE the rounded card, then the card holds
--  a vertical list of elements with internal padding. Wrapper is
--  an autosizing frame so columns flow nicely.
-- ============================================================
local function buildGroupbox(parent, name)
    -- Outer wrapper hosting [ title ] + [ card ]
    local wrap = newFrame("Groupbox", parent, {
        Size = UDim2.new(1, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1,
    })
    local wrapLayout = listLayout(wrap, 6)
    wrapLayout.SortOrder = Enum.SortOrder.LayoutOrder

    -- Section title ( uppercase, dim, sits ABOVE the card )
    local titleHolder = newFrame("Title", wrap, {
        Size = UDim2.new(1, 0, 0, 18),
        BackgroundTransparency = 1,
        LayoutOrder = 1,
    })
    padding(titleHolder, { l = 4 })
    local titleLbl = newLabel(titleHolder, name or "", 12, Scheme.DimColor,
        Enum.Font.GothamBold, Enum.TextXAlignment.Left)
    titleLbl.Text = name or ""
    register(titleLbl, "TextColor3", "DimColor")

    -- Rounded card hosting elements. We deliberately skip a UIStroke
    -- here : the strong border was making the UI look unfinished.
    -- Instead we rely on the GroupboxColor differential against the
    -- backdrop + a faint translucency to give the card a clean
    -- "frosted" look.
    local card = newFrame("Card", wrap, {
        Size = UDim2.new(1, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundColor3 = Scheme.GroupboxColor,
        BackgroundTransparency = 0.1,
        LayoutOrder = 2,
        ZIndex = 2,
    })
    register(card, "BackgroundColor3", "GroupboxColor")
    corner(card, 10)
    -- Faint outline so the card has a defined edge against the page
    -- ( the user asked for "des traits gris qui font beau" ).
    local cardStroke = stroke(card, Scheme.OutlineColor, 1, 0.7)
    register(cardStroke, "Color", "OutlineColor")
    padding(card, { t = 10, b = 10, l = 10, r = 10 })

    -- Subtle gradient on each card so they read with a hint of
    -- depth against the page backdrop.
    local cardGrad = Instance.new("UIGradient")
    cardGrad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0,    Color3.fromRGB(255, 255, 255)),
        ColorSequenceKeypoint.new(1,    Color3.fromRGB(210, 210, 215)),
    })
    cardGrad.Rotation = 90
    cardGrad.Parent = card

    -- Element holder ( where rows are appended )
    local body = newFrame("Body", card, {
        Size = UDim2.new(1, 0, 0, 0),
        BackgroundTransparency = 1,
        AutomaticSize = Enum.AutomaticSize.Y,
    })
    local layout = listLayout(body, 4)

    local g = { _body = body, _card = card, _title = titleLbl, _wrap = wrap }

    function g:AddToggle(idx, opts)   return buildToggle(self._body, idx, opts) end
    function g:AddSlider(idx, opts)   return buildSlider(self._body, idx, opts) end
    function g:AddButton(arg, cb)     return buildButton(self._body, arg, cb)   end
    function g:AddLabel(text, wrap)   return buildLabel(self._body, text, wrap) end
    function g:AddDivider()           return buildDivider(self._body)           end

    -- Dropdown / Input are loaded lazily ( defined in Chunk 2 ).
    -- We attach pass-through stubs now and overwrite when the
    -- second chunk attaches itself. Library._BuildDropdown /
    -- Library._BuildInput hooks are populated by Chunk 2.
    function g:AddDropdown(idx, opts)
        if Library._BuildDropdown then
            return Library._BuildDropdown(self._body, idx, opts)
        end
        return buildLabel(self._body, "[Dropdown not loaded]")
    end
    function g:AddInput(idx, opts)
        if Library._BuildInput then
            return Library._BuildInput(self._body, idx, opts)
        end
        return buildLabel(self._body, "[Input not loaded]")
    end

    return g
end

-- ============================================================
--  TAB FACTORY
--  Each tab owns :
--    * A sidebar entry ( clickable row in the left rail )
--    * A content frame ( shown when active, hidden otherwise )
--      with two scrollable columns hosting groupboxes
-- ============================================================
local function buildTab(window, name, icon, category)
    local sidebar = window._Sidebar
    local pages   = window._Pages

    -- Resolve category slot ( header LO = slot*100, tabs LO = slot*100 + n )
    local catKey = category or "_default"
    local cat    = sidebar._CatSeen[catKey]
    if not cat then
        sidebar._CatCount = sidebar._CatCount + 1
        cat = { slot = sidebar._CatCount, tabCount = 0 }
        sidebar._CatSeen[catKey] = cat
    end
    cat.tabCount = cat.tabCount + 1

    -- ===== Sidebar entry =====
    local entry = newFrame("Entry_" .. name, sidebar._Holder, {
        Size = UDim2.new(1, 0, 0, 32),
        BackgroundColor3 = Scheme.SidebarColor,
        BackgroundTransparency = 1,
        LayoutOrder = cat.slot * 100 + cat.tabCount,
    })
    corner(entry, 6)

    local entryBtn = newButton(entry, {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 1, 0),
        Text = "",
    })

    local accent = newFrame("Accent", entry, {
        Size = UDim2.new(0, 3, 0.6, 0),
        Position = UDim2.new(0, 0, 0.2, 0),
        BackgroundColor3 = Scheme.AccentColor,
        BackgroundTransparency = 1,  -- hidden until selected
    })
    register(accent, "BackgroundColor3", "AccentColor")
    corner(accent, 2)

    -- Refs are stored in a Lua table because Roblox Instances reject
    -- arbitrary property assignments ( e.g. `entry._Icon = img` would
    -- throw "_Icon is not a valid member of Frame" ).
    local entryRefs = {
        _Frame  = entry,
        _Accent = accent,
        _Icon   = nil,
        _Label  = nil,
    }

    if icon then
        local img = newImage(entry, "", {
            Size = UDim2.new(0, 18, 0, 18),
            Position = UDim2.new(0, 12, 0.5, -9),
            ImageColor3 = Scheme.SubFontColor,
        })
        applyIcon(img, icon, 48)
        register(img, "ImageColor3", "SubFontColor")
        entryRefs._Icon = img
    end

    local entryLbl = newLabel(entry, name, 13, Scheme.SubFontColor,
        Enum.Font.GothamMedium, Enum.TextXAlignment.Left)
    entryLbl.Position = UDim2.new(0, icon and 38 or 14, 0, 0)
    entryLbl.Size = UDim2.new(1, -40, 1, 0)
    register(entryLbl, "TextColor3", "SubFontColor")
    entryRefs._Label = entryLbl

    -- ===== Content page =====
    -- Using a CanvasGroup ( not Frame ) so we can tween a single
    -- GroupTransparency across all descendants. This powers the
    -- fade-in / fade-out crossfade between tabs in _SelectTab.
    local page = Instance.new("CanvasGroup")
    page.Name = "Page_" .. name
    page.Size = UDim2.new(1, 0, 1, 0)
    page.BackgroundTransparency = 1
    page.GroupTransparency = 0
    page.Visible = false
    page.Parent = pages

    -- Two scrollable columns
    local function makeCol(side)
        local sf = Instance.new("ScrollingFrame")
        sf.Name = "Col_" .. side
        sf.BackgroundTransparency = 1
        sf.BorderSizePixel = 0
        sf.ScrollBarThickness = 3
        sf.ScrollBarImageColor3 = Scheme.AccentColor
        register(sf, "ScrollBarImageColor3", "AccentColor")
        sf.AutomaticCanvasSize = Enum.AutomaticSize.Y
        sf.CanvasSize = UDim2.new(0, 0, 0, 0)
        sf.ScrollingDirection = Enum.ScrollingDirection.Y
        sf.Size = UDim2.new(0.5, -8, 1, 0)
        sf.Position = side == "Left" and UDim2.new(0, 0, 0, 0)
            or UDim2.new(0.5, 8, 0, 0)
        sf.Parent = page

        local body = newFrame("Body", sf, {
            Size = UDim2.new(1, -6, 0, 0),
            BackgroundTransparency = 1,
            AutomaticSize = Enum.AutomaticSize.Y,
        })
        local lyt = listLayout(body, 12)

        -- Roblox SFs with AutomaticCanvasSize sometimes drift to a
        -- non-zero CanvasPosition when child content is appended.
        -- Snap back to the top while elements are being added so the
        -- user always sees the page from row #1. After 1.5 s the
        -- snapping releases and the user has free scroll control.
        local startedAt = os.clock()
        local conn
        conn = lyt:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            sf.CanvasPosition = Vector2.zero
            if os.clock() - startedAt > 1.5 then
                if conn then conn:Disconnect() conn = nil end
            end
        end)

        return body
    end
    local leftCol  = makeCol("Left")
    local rightCol = makeCol("Right")

    local tab = {
        _Name = name,
        _Entry = entryRefs,
        _Page = page,
        _LeftCol = leftCol,
        _RightCol = rightCol,
    }

    function tab:AddLeftGroupbox(label)
        return buildGroupbox(self._LeftCol, label)
    end
    function tab:AddRightGroupbox(label)
        return buildGroupbox(self._RightCol, label)
    end

    -- Activate handler ( delegated to window:_SelectTab )
    entryBtn.MouseButton1Click:Connect(function()
        window:_SelectTab(name)
    end)

    -- Hover effect on idle entries
    entryBtn.MouseEnter:Connect(function()
        if window._ActiveTab ~= name then
            tween(entry, TI_FAST, { BackgroundTransparency = 0.7 })
            tween(entry, TI_FAST, { BackgroundColor3 = Scheme.HoverColor })
        end
    end)
    entryBtn.MouseLeave:Connect(function()
        if window._ActiveTab ~= name then
            tween(entry, TI_FAST, { BackgroundTransparency = 1 })
        end
    end)

    -- Categorise : on first tab of this category, prepend a header
    if category and cat.tabCount == 1 then
        local hdr = newFrame("Cat_" .. category, sidebar._Holder, {
            Size = UDim2.new(1, 0, 0, 24),
            BackgroundTransparency = 1,
            LayoutOrder = cat.slot * 100,  -- header just above its tabs
        })
        local hl = newLabel(hdr, string.upper(category), 11,
            Scheme.DimColor, Enum.Font.GothamBold,
            Enum.TextXAlignment.Left)
        hl.Position = UDim2.new(0, 8, 0, 6)
        hl.Size = UDim2.new(1, -8, 0, 14)
        register(hl, "TextColor3", "DimColor")
    end

    table.insert(window._Tabs, tab)
    Library._Tabs[name] = tab
    return tab
end

-- ============================================================
--  WINDOW FACTORY ( Library:CreateWindow main entry )
--  Builds the entire shell : ScreenGui -> Root -> Sidebar +
--  Topbar + Pages region. Returns a Window object exposing
--  :AddTab() and a private :_SelectTab() switch helper.
-- ============================================================
function Library:CreateWindow(opts)
    opts = opts or {}
    local title  = opts.Title or "AXON HUB"
    local footer = opts.Footer  -- nil triggers async game-name resolve below
    local size   = opts.Size or UDim2.fromOffset(720, 480)
    local center = opts.Center ~= false

    -- ===== ScreenGui root =====
    local sg = Instance.new("ScreenGui")
    sg.Name = "ArvynLib_Window"
    sg.IgnoreGuiInset = true
    sg.ResetOnSpawn = false
    sg.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    sg.DisplayOrder = 9990
    sg.Parent = pickParent()
    self._ScreenGui = sg

    -- ===== Backdrop ( the actual window box ) =====
    -- Active = true is critical : it makes the frame consume mouse
    -- input so clicks don't bleed through to camera control. Without
    -- it, clicking a toggle could be interpreted as a world click,
    -- causing the cursor to vanish into camera-rotate mode.
    --
    -- Slight BackgroundTransparency + vertical UIGradient give the
    -- window a subtle "frosted glass" feel rather than a flat black
    -- rectangle.
    local root = newFrame("Root", sg, {
        Size = size,
        Position = center and UDim2.new(0.5, 0, 0.5, 0) or UDim2.new(0, 50, 0, 50),
        AnchorPoint = center and Vector2.new(0.5, 0.5) or Vector2.new(0, 0),
        BackgroundColor3 = Scheme.BackgroundColor,
        BackgroundTransparency = 0.05,
        Active = true,
    })
    register(root, "BackgroundColor3", "BackgroundColor")
    corner(root, 14)
    local rs = stroke(root, Scheme.OutlineColor, 1, 0.7)
    register(rs, "Color", "OutlineColor")
    -- Subtle top-to-bottom shading : top is slightly brighter than
    -- the bottom, mimicking a frosted glass surface.
    local rootGrad = Instance.new("UIGradient")
    rootGrad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0,    Color3.fromRGB(255, 255, 255)),
        ColorSequenceKeypoint.new(1,    Color3.fromRGB(195, 195, 200)),
    })
    rootGrad.Rotation = 90
    rootGrad.Parent = root
    self._MainWindow = root

    -- ===== Sidebar ( left rail ) =====
    local sidebar = newFrame("Sidebar", root, {
        Size = UDim2.new(0, 200, 1, 0),
        BackgroundColor3 = Scheme.SidebarColor,
        BackgroundTransparency = 0.15,
    })
    register(sidebar, "BackgroundColor3", "SidebarColor")
    corner(sidebar, 12)
    -- Cover right rounded corners so the sidebar joins flush with content
    local cover = newFrame("Cover", sidebar, {
        AnchorPoint = Vector2.new(1, 0),
        Position = UDim2.new(1, 0, 0, 0),
        Size = UDim2.new(0, 12, 1, 0),
        BackgroundColor3 = Scheme.SidebarColor,
    })
    register(cover, "BackgroundColor3", "SidebarColor")
    -- Right divider line
    local divLine = newFrame("DivLine", sidebar, {
        AnchorPoint = Vector2.new(1, 0),
        Position = UDim2.new(1, 0, 0, 0),
        Size = UDim2.new(0, 1, 1, 0),
        BackgroundColor3 = Scheme.OutlineColor,
        BackgroundTransparency = 0.4,
    })
    register(divLine, "BackgroundColor3", "OutlineColor")

    -- Logo block at top of sidebar
    local logo = newFrame("Logo", sidebar, {
        Size = UDim2.new(1, 0, 0, 56),
        BackgroundTransparency = 1,
    })
    local logoIcon = newFrame("LogoIcon", logo, {
        AnchorPoint = Vector2.new(0, 0.5),
        Position = UDim2.new(0, 12, 0.5, 0),
        Size = UDim2.new(0, 44, 0, 44),
        BackgroundColor3 = Scheme.ElementColor,
    })
    register(logoIcon, "BackgroundColor3", "ElementColor")
    corner(logoIcon, 8)

    -- Logo icon : opts.Icon dispatches to :
    --   * "game"            -> Roblox game icon ( rbxthumb )
    --   * "<lucide-name>"   -> a Lucide line icon centred on the box
    --   * "rbxassetid://X"  -> any Roblox asset id ( image / decal )
    --   * nil               -> default AxonHub logo asset
    local DEFAULT_LOGO_ASSET = resolveAxonLogo()
    logoIcon.BackgroundTransparency = 1
    if opts.Icon == "game" then
        local gameImg = Instance.new("ImageLabel")
        gameImg.Name = "GameIcon"
        gameImg.BackgroundTransparency = 1
        gameImg.BorderSizePixel = 0
        gameImg.AnchorPoint = Vector2.new(0.5, 0.5)
        gameImg.Position = UDim2.new(0.5, 0, 0.5, 0)
        gameImg.Size = UDim2.new(1, 0, 1, 0)
        gameImg.Image = "rbxthumb://type=GameIcon&id=" .. tostring(game.PlaceId) .. "&w=150&h=150"
        gameImg.ScaleType = Enum.ScaleType.Fit
        gameImg.Parent = logoIcon
        corner(gameImg, 6)
    elseif type(opts.Icon) == "string" and opts.Icon:sub(1, 4) ~= "rbxa" and opts.Icon ~= "" and opts.Icon ~= "axon" then
        local play = newImage(logoIcon, "", {
            AnchorPoint = Vector2.new(0.5, 0.5),
            Position = UDim2.new(0.5, 0, 0.5, 0),
            Size = UDim2.new(0, 18, 0, 18),
            ImageColor3 = Color3.fromRGB(255, 255, 255),
        })
        applyIcon(play, opts.Icon, 48)
    else
        local logoImg = Instance.new("ImageLabel")
        logoImg.Name = "LogoImg"
        logoImg.BackgroundTransparency = 1
        logoImg.BorderSizePixel = 0
        logoImg.AnchorPoint = Vector2.new(0.5, 0.5)
        logoImg.Position = UDim2.new(0.5, 0, 0.5, 0)
        logoImg.Size = UDim2.new(1, 0, 1, 0)
        logoImg.Image = (type(opts.Icon) == "string" and opts.Icon ~= "") and opts.Icon or DEFAULT_LOGO_ASSET
        logoImg.ScaleType = Enum.ScaleType.Fit
        logoImg.ZIndex = 2
        logoImg.Parent = logoIcon

        -- Fallback "A" letter shown while the asset loads ( or
        -- permanently if the asset is moderation-pending / private ).
        local fallback = Instance.new("TextLabel")
        fallback.Name = "AFallback"
        fallback.BackgroundTransparency = 1
        fallback.Size = UDim2.new(1, 0, 1, 0)
        fallback.Position = UDim2.new(0, 0, 0, -1)
        fallback.Text = "A"
        fallback.Font = Enum.Font.GothamBlack
        fallback.TextSize = 24
        fallback.TextColor3 = Color3.fromRGB(235, 235, 240)
        fallback.ZIndex = 1
        fallback.Parent = logoIcon

        -- Hide the fallback as soon as the real image renders.
        -- IsLoaded under-reports for getcustomasset textures, so we
        -- also treat "rbxasset://textures/..." paths as visible.
        local function syncFallback()
            local img = logoImg.Image or ""
            local isLocal = img:sub(1, 19) == "rbxasset://textures"
            fallback.Visible = not (logoImg.IsLoaded or isLocal)
        end
        syncFallback()
        logoImg:GetPropertyChangedSignal("IsLoaded"):Connect(syncFallback)
        task.delay(2, syncFallback)
    end

    local titleLbl = newLabel(logo, title, 14, Scheme.FontColor,
        Enum.Font.GothamBold, Enum.TextXAlignment.Left)
    titleLbl.Position = UDim2.new(0, 68, 0, 12)
    titleLbl.Size = UDim2.new(1, -76, 0, 16)
    register(titleLbl, "TextColor3", "FontColor")

    -- Sub-label : if the caller didn't pass a Footer, async-resolve
    -- the Roblox game name via MarketplaceService and inject it as
    -- soon as the request comes back. We also strip leading [tag]
    -- prefixes ( "[🍀2x Chance🍀] Foo" -> "Foo" ) because the emoji
    -- chars don't render in Gotham.
    if footer ~= "" then
        local initial = footer or "..."
        local subLbl = newLabel(logo, initial, 11, Scheme.DimColor,
            Enum.Font.Gotham, Enum.TextXAlignment.Left)
        subLbl.Position = UDim2.new(0, 68, 0, 30)
        subLbl.Size = UDim2.new(1, -76, 0, 14)
        subLbl.TextTruncate = Enum.TextTruncate.AtEnd
        register(subLbl, "TextColor3", "DimColor")
        if footer == nil then
            task.spawn(function()
                local ok, info = pcall(function()
                    return game:GetService("MarketplaceService"):GetProductInfo(game.PlaceId)
                end)
                if ok and info and info.Name and subLbl and subLbl.Parent then
                    local clean = info.Name
                    -- Strip every leading "[..]" group + surrounding spaces.
                    while true do
                        local next = clean:gsub("^%s*%[[^%]]*%]%s*", "")
                        if next == clean then break end
                        clean = next
                    end
                    clean = clean:gsub("^%s+", ""):gsub("%s+$", "")
                    if clean ~= "" then subLbl.Text = clean end
                end
            end)
        end
    end

    -- Sidebar tab list ( categorised ).
    local sbHolder = newFrame("Tabs", sidebar, {
        Position = UDim2.new(0, 0, 0, 64),
        Size = UDim2.new(1, 0, 1, -120),
        BackgroundTransparency = 1,
    })
    padding(sbHolder, { l = 8, r = 8, t = 4, b = 4 })
    local sbLayout = listLayout(sbHolder, 4)

    -- Profile card at bottom of sidebar
    local profile = newFrame("Profile", sidebar, {
        AnchorPoint = Vector2.new(0, 1),
        Position = UDim2.new(0, 8, 1, -8),
        Size = UDim2.new(1, -16, 0, 48),
        BackgroundColor3 = Scheme.GroupboxColor,
        BackgroundTransparency = 0.1,
    })
    register(profile, "BackgroundColor3", "GroupboxColor")
    corner(profile, 8)
    -- Real player avatar headshot via Roblox's rbxthumb : protocol
    -- ( no GetUserThumbnailAsync HTTP roundtrip needed, the client
    -- resolves it locally ).
    local pIcon = Instance.new("ImageLabel")
    pIcon.Name = "PIcon"
    pIcon.AnchorPoint = Vector2.new(0, 0.5)
    pIcon.Position = UDim2.new(0, 8, 0.5, 0)
    pIcon.Size = UDim2.new(0, 32, 0, 32)
    pIcon.BackgroundColor3 = Scheme.ElementColor
    pIcon.BackgroundTransparency = 0
    pIcon.BorderSizePixel = 0
    pIcon.Image = "rbxthumb://type=AvatarHeadShot&id=" .. tostring(LocalPlayer.UserId) .. "&w=150&h=150"
    pIcon.ScaleType = Enum.ScaleType.Crop
    pIcon.Parent = profile
    corner(pIcon, 16)
    register(pIcon, "BackgroundColor3", "ElementColor")

    local pName = newLabel(profile, LocalPlayer.DisplayName or LocalPlayer.Name or "User", 12,
        Scheme.FontColor, Enum.Font.GothamBold, Enum.TextXAlignment.Left)
    pName.Position = UDim2.new(0, 48, 0, 6)
    pName.Size = UDim2.new(1, -78, 0, 14)
    pName.TextTruncate = Enum.TextTruncate.AtEnd
    register(pName, "TextColor3", "FontColor")
    local pSub = newLabel(profile, "AxonHub - Free", 10,
        Scheme.DimColor, Enum.Font.Gotham, Enum.TextXAlignment.Left)
    pSub.Position = UDim2.new(0, 48, 0, 22)
    pSub.Size = UDim2.new(1, -78, 0, 14)
    pSub.TextTruncate = Enum.TextTruncate.AtEnd
    register(pSub, "TextColor3", "DimColor")

    -- Chevron pointing right ( matches the Arvyn Hub reference ).
    -- Purely decorative for now, future hooks can expose a click.
    local pChev = newImage(profile, "", {
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, -8, 0.5, 0),
        Size = UDim2.new(0, 14, 0, 14),
        ImageColor3 = Scheme.DimColor,
    })
    applyIcon(pChev, "chevron-right", 48)
    register(pChev, "ImageColor3", "DimColor")

    -- ===== Topbar ( title + drag handle + close button ) =====
    local topbar = newFrame("Topbar", root, {
        Position = UDim2.new(0, 200, 0, 0),
        Size = UDim2.new(1, -200, 0, 56),
        BackgroundColor3 = Scheme.TopbarColor,
        BackgroundTransparency = 0.15,
    })
    register(topbar, "BackgroundColor3", "TopbarColor")
    -- Bottom border
    local tbBorder = newFrame("Border", topbar, {
        AnchorPoint = Vector2.new(0, 1),
        Position = UDim2.new(0, 0, 1, 0),
        Size = UDim2.new(1, 0, 0, 1),
        BackgroundColor3 = Scheme.OutlineColor,
        BackgroundTransparency = 0.4,
    })
    register(tbBorder, "BackgroundColor3", "OutlineColor")

    -- Topbar config indicator removed ( user request ). Config
    -- switching is handled exclusively from the UI Settings tab,
    -- so the read-only "Default" pill is no longer drawn here.

    -- Live FPS + ping readout in the top right of the topbar.
    -- Replaces the previous blue AxonHub badge ( user asked for no
    -- blue accents in the chrome ). Wordmark stays in plain dim text.
    local statsLbl = newLabel(topbar, "Axon Hub  |  FPS: --  |  Ping: --ms", 12,
        Scheme.SubFontColor, Enum.Font.GothamMedium, Enum.TextXAlignment.Right)
    statsLbl.AnchorPoint = Vector2.new(1, 0.5)
    statsLbl.Position = UDim2.new(1, -52, 0.5, 0)
    statsLbl.Size = UDim2.new(0, 240, 0, 20)
    register(statsLbl, "TextColor3", "SubFontColor")

    -- Drive the stats with a Heartbeat loop ; FPS computed from
    -- frame time, ping fetched from the local Player network info.
    do
        local frames, accum = 0, 0
        local fps = 0
        local Stats = game:GetService("Stats")
        local function getPing()
            local ok, v = pcall(function()
                return LocalPlayer:GetNetworkPing() * 1000
            end)
            if ok and type(v) == "number" then return math.floor(v) end
            local ok2, v2 = pcall(function()
                return Stats.Network.ServerStatsItem["Data Ping"]:GetValue()
            end)
            if ok2 and type(v2) == "number" then return math.floor(v2) end
            return 0
        end
        local conn
        conn = RunService.Heartbeat:Connect(function(dt)
            frames = frames + 1
            accum  = accum + dt
            if accum >= 0.5 then
                fps   = math.floor(frames / accum + 0.5)
                frames = 0
                accum  = 0
                if statsLbl and statsLbl.Parent then
                    statsLbl.Text = string.format("Axon Hub  |  FPS: %d  |  Ping: %dms", fps, getPing())
                else
                    -- Stop the loop if the GUI was unloaded.
                    if conn then conn:Disconnect() conn = nil end
                end
            end
        end)
    end

    -- Right side : close button. Uses a real Lucide "x" icon
    -- because the Unicode ✕ glyph mis-renders as "âœ•" mojibake on
    -- some Roblox font fallback paths.
    local closeBtn = newButton(topbar, {
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, -16, 0.5, 0),
        Size = UDim2.new(0, 28, 0, 28),
        BackgroundColor3 = Scheme.ElementColor,
        BackgroundTransparency = 0.3,
        Text = "",
    })
    register(closeBtn, "BackgroundColor3", "ElementColor")
    corner(closeBtn, 6)
    local closeIcon = newImage(closeBtn, "", {
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(0.5, 0, 0.5, 0),
        Size = UDim2.new(0, 14, 0, 14),
        ImageColor3 = Scheme.SubFontColor,
    })
    applyIcon(closeIcon, "x", 48)
    register(closeIcon, "ImageColor3", "SubFontColor")
    closeBtn.MouseButton1Click:Connect(function()
        Library:Unload()
    end)
    bindHover(closeBtn, "BackgroundColor3", "ElementColor", "HoverColor")

    -- ===== Pages region ( holds tab content ) =====
    local pages = newFrame("Pages", root, {
        Position = UDim2.new(0, 200, 0, 56),
        Size = UDim2.new(1, -200, 1, -56),
        BackgroundTransparency = 1,
    })
    padding(pages, { t = 16, b = 16, l = 16, r = 16 })

    -- Drag handle = topbar
    makeDraggable(topbar, root)

    -- Sidebar object ( category bookkeeping )
    local sidebarObj = {
        _Holder   = sbHolder,
        _CatSeen  = {},
        _CatCount = 0,
    }

    -- ===== Window object =====
    local window = {
        _Root      = root,
        _Sidebar   = sidebarObj,
        _Pages     = pages,
        _Tabs      = {},
        _ActiveTab = nil,
    }

    function window:_SelectTab(name)
        local TI_TAB_IN  = TweenInfo.new(0.22, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
        local TI_TAB_OUT = TweenInfo.new(0.14, Enum.EasingStyle.Quad,  Enum.EasingDirection.Out)
        for _, t in ipairs(self._Tabs) do
            local on = t._Name == name
            local frame = t._Entry._Frame

            if on then
                -- Reset scroll + slide / fade the new page in
                for _, c in ipairs(t._Page:GetChildren()) do
                    if c:IsA("ScrollingFrame") then
                        c.CanvasPosition = Vector2.zero
                    end
                end
                t._Page.Visible = true
                t._Page.Position = UDim2.new(0, 12, 0, 0)
                t._Page.GroupTransparency = 1
                tween(t._Page, TI_TAB_IN, {
                    Position = UDim2.new(0, 0, 0, 0),
                    GroupTransparency = 0,
                })
            elseif t._Page.Visible then
                -- Fade out the previously active page, hide once invisible.
                local oldPage = t._Page
                tween(oldPage, TI_TAB_OUT, { GroupTransparency = 1 })
                task.delay(0.16, function()
                    if self._ActiveTab ~= t._Name and oldPage and oldPage.Parent then
                        oldPage.Visible = false
                    end
                end)
            end
            tween(frame, TI_FAST, {
                BackgroundColor3 = on and Scheme.ElementColor or Scheme.SidebarColor,
                BackgroundTransparency = on and 0.2 or 1,
            })
            tween(t._Entry._Accent, TI_FAST, {
                BackgroundTransparency = on and 0 or 1,
            })
            tween(t._Entry._Label, TI_FAST, {
                TextColor3 = on and Scheme.FontColor or Scheme.SubFontColor,
            })
            if t._Entry._Icon then
                tween(t._Entry._Icon, TI_FAST, {
                    ImageColor3 = on and Scheme.AccentColor or Scheme.SubFontColor,
                })
            end
            if on then
                register(frame, "BackgroundColor3", "ElementColor")
                register(t._Entry._Label, "TextColor3", "FontColor")
                if t._Entry._Icon then
                    register(t._Entry._Icon, "ImageColor3", "AccentColor")
                end
            else
                register(frame, "BackgroundColor3", "SidebarColor")
                register(t._Entry._Label, "TextColor3", "SubFontColor")
                if t._Entry._Icon then
                    register(t._Entry._Icon, "ImageColor3", "SubFontColor")
                end
            end
        end
        self._ActiveTab = name
    end

    function window:AddTab(name, icon, category)
        local t = buildTab(self, name, icon, category)
        if not self._ActiveTab then
            self:_SelectTab(name)
        end
        return t
    end

    return window
end

-- ============================================================
--  POPUP MANAGER ( one popup open at a time + click-outside )
--  Used by dropdowns and the topbar config button. Anchored to
--  the same ScreenGui as the originating row so DisplayOrder is
--  inherited automatically.
-- ============================================================
local _activePopup = nil
local function setActivePopup(handle)
    if _activePopup and _activePopup ~= handle and _activePopup.close then
        pcall(_activePopup.close)
    end
    _activePopup = handle
end
local function clearActivePopup(handle)
    if _activePopup == handle then _activePopup = nil end
end

UserInputService.InputBegan:Connect(function(input, gp)
    if not _activePopup or not _activePopup.frame or not _activePopup.frame.Parent then return end
    if input.UserInputType ~= Enum.UserInputType.MouseButton1
       and input.UserInputType ~= Enum.UserInputType.Touch then return end
    -- Defer so the same click doesn't immediately close the popup
    task.defer(function()
        local h = _activePopup
        if not h or not h.frame or not h.frame.Parent then return end
        local pos, sz = h.frame.AbsolutePosition, h.frame.AbsoluteSize
        local mp = input.Position
        if mp.X < pos.X or mp.X > pos.X + sz.X
           or mp.Y < pos.Y or mp.Y > pos.Y + sz.Y then
            -- Also check the anchor row, so clicking the row again toggles
            local a = h.anchor
            if a then
                local apos, asz = a.AbsolutePosition, a.AbsoluteSize
                if mp.X >= apos.X and mp.X <= apos.X + asz.X
                   and mp.Y >= apos.Y and mp.Y <= apos.Y + asz.Y then
                    return -- the row's own click handler will toggle
                end
            end
            pcall(h.close)
        end
    end)
end)

-- ============================================================
--  DROPDOWN FACTORY ( single + multi + search )
--  Visual : row [ label ........ value ▾ ] in card body. Click
--  spawns a popup parented to the host ScreenGui so it can
--  overlay any other element. Search filter on top, hover row
--  highlight, soft accent on selected entries.
--
--  opts = {
--      Text       = "Mode",
--      Values     = { "A", "B", "C" },
--      Default    = "A"  or  { A = true, C = true } / { "A", "C" },
--      Multi      = false,        -- multi-select mode
--      Searchable = true,         -- search box at top of popup
--      Callback   = function(v) end,
--      AllowNull  = true,         -- single mode allows nil
--  }
-- ============================================================
local function buildDropdown(parent, idx, opts)
    opts = opts or {}
    local text       = opts.Text or idx
    local values     = opts.Values or {}
    local multi      = opts.Multi == true
    local searchable = opts.Searchable ~= false
    local callback   = opts.Callback
    local allowNull  = opts.AllowNull ~= false

    -- Normalise default
    local function normaliseDefault(d)
        if multi then
            local out = {}
            if type(d) == "table" then
                if next(d) then
                    -- list-form vs set-form
                    if d[1] ~= nil then
                        for _, v in ipairs(d) do out[v] = true end
                    else
                        for k, v in pairs(d) do
                            if v == true and type(k) == "string" then
                                out[k] = true
                            end
                        end
                    end
                end
            end
            return out
        else
            if type(d) == "string" then return d end
            if type(d) == "table" and d[1] then return d[1] end
            return nil
        end
    end

    local row = newFrame("Dropdown_" .. tostring(idx), parent, {
        Size = UDim2.new(1, 0, 0, 36),
        BackgroundColor3 = Scheme.ElementColor,
        BackgroundTransparency = 0,
    })
    register(row, "BackgroundColor3", "ElementColor")
    corner(row, 7)
    local rowStroke = stroke(row, Scheme.OutlineColor, 1, 0.7)
    register(rowStroke, "Color", "OutlineColor")
    padding(row, { l = 12, r = 10 })

    local btn = newButton(row, {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = "",
    })

    local lbl = newLabel(row, text, 13, Scheme.FontColor,
        Enum.Font.GothamMedium, Enum.TextXAlignment.Left)
    lbl.Size = UDim2.new(0.4, 0, 1, 0)
    register(lbl, "TextColor3", "FontColor")

    -- Optional more-options dots ( hidden unless opts.OnConfig set,
    -- because dropdowns already get a chevron on the right ).
    local dotsBtn
    if type(opts.OnConfig) == "function" then
        dotsBtn = newButton(row, {
            AnchorPoint = Vector2.new(1, 0.5),
            Position = UDim2.new(1, -38, 0.5, 0),
            Size = UDim2.new(0, 22, 0, 22),
            BackgroundTransparency = 1,
            Text = "",
        })
        local di = newImage(dotsBtn, "", {
            AnchorPoint = Vector2.new(0.5, 0.5),
            Position = UDim2.new(0.5, 0, 0.5, 0),
            Size = UDim2.new(0, 16, 0, 16),
            ImageColor3 = Scheme.DimColor,
        })
        applyIcon(di, "more-horizontal", 48)
        register(di, "ImageColor3", "DimColor")
        dotsBtn.MouseButton1Click:Connect(function() pcall(opts.OnConfig) end)
    end

    local valLbl = newLabel(row, "---", 13, Scheme.SubFontColor,
        Enum.Font.GothamMedium, Enum.TextXAlignment.Right)
    valLbl.AnchorPoint = Vector2.new(1, 0.5)
    valLbl.Position = UDim2.new(1, -22, 0.5, 0)
    valLbl.Size = UDim2.new(0.6, dotsBtn and -56 or -28, 1, 0)
    valLbl.TextTruncate = Enum.TextTruncate.AtEnd
    register(valLbl, "TextColor3", "SubFontColor")

    local chev = newImage(row, "", {
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, 0, 0.5, 0),
        Size = UDim2.new(0, 14, 0, 14),
        ImageColor3 = Scheme.SubFontColor,
    })
    applyIcon(chev, "chevron-down", 48)
    register(chev, "ImageColor3", "SubFontColor")

    local obj = {
        Value    = normaliseDefault(opts.Default),
        Values   = values,
        _changed = {},
        _idx     = idx,
        _multi   = multi,
    }

    local function fmtValue()
        if multi then
            local parts = {}
            for v, b in pairs(obj.Value) do
                if b then table.insert(parts, v) end
            end
            if #parts == 0 then return "None" end
            if #parts > 3 then return ("%d selected"):format(#parts) end
            return table.concat(parts, ", ")
        else
            return obj.Value or "---"
        end
    end

    local function refreshValueLabel()
        valLbl.Text = fmtValue()
    end
    refreshValueLabel()

    -- ===== Popup =====
    local popup, popupRows, searchBox
    local popupHandle = {}

    local function destroyPopup()
        if popup then
            tween(popup, TI_FAST, { BackgroundTransparency = 1 })
            local p = popup
            task.delay(0.13, function() if p then p:Destroy() end end)
            popup = nil
            popupRows = nil
            searchBox = nil
        end
        clearActivePopup(popupHandle)
        tween(chev, TI_FAST, { Rotation = 0 })
    end
    popupHandle.close = destroyPopup
    popupHandle.anchor = row

    local function buildPopup()
        local sg = row:FindFirstAncestorWhichIsA("ScreenGui")
        if not sg then return end

        -- Geometry
        local rowPos  = row.AbsolutePosition
        local rowSz   = row.AbsoluteSize
        local guiAbs  = sg.AbsolutePosition

        local rowCount = math.min(#values, 6)
        local rowH     = 28
        local searchH  = searchable and 32 or 0
        local pad      = 8
        local spacing  = 4
        local totalH   = pad * 2 + searchH + (searchable and spacing or 0) + (rowH * rowCount) + (math.max(rowCount - 1, 0) * spacing)

        popup = newFrame("Popup_" .. tostring(idx), sg, {
            Position = UDim2.fromOffset(rowPos.X - guiAbs.X, rowPos.Y - guiAbs.Y + rowSz.Y + 4),
            Size     = UDim2.fromOffset(rowSz.X, totalH),
            BackgroundColor3 = Scheme.GroupboxColor,
            BackgroundTransparency = 0,
            ZIndex = 50,
        })
        register(popup, "BackgroundColor3", "GroupboxColor")
        corner(popup, 10)
        local s = stroke(popup, Scheme.OutlineColor, 1, 0.4)
        register(s, "Color", "OutlineColor")
        padding(popup, { t = pad, b = pad, l = pad, r = pad })

        -- Inner scroll list
        local list = Instance.new("ScrollingFrame")
        list.BackgroundTransparency = 1
        list.BorderSizePixel = 0
        list.ScrollBarThickness = 3
        list.ScrollBarImageColor3 = Scheme.AccentColor
        register(list, "ScrollBarImageColor3", "AccentColor")
        list.AutomaticCanvasSize = Enum.AutomaticSize.Y
        list.CanvasSize = UDim2.new(0, 0, 0, 0)
        list.Size = UDim2.new(1, 0, 1, -(searchable and (searchH + spacing) or 0))
        list.Position = UDim2.new(0, 0, 0, searchable and (searchH + spacing) or 0)
        list.Parent = popup
        list.ZIndex = 51
        local listLayoutObj = listLayout(list, spacing)

        -- Search box ( on top ). Note : we DON'T use UIPadding on
        -- the box because that would also shift the icon child.
        -- Instead we hand-position both the icon and the textbox.
        local searchText = ""
        if searchable then
            local box = newFrame("Search", popup, {
                Size = UDim2.new(1, 0, 0, searchH),
                BackgroundColor3 = Scheme.ElementColor,
                BackgroundTransparency = 0.2,
                ZIndex = 51,
            })
            register(box, "BackgroundColor3", "ElementColor")
            corner(box, 6)
            local searchIcon = newImage(box, "", {
                AnchorPoint = Vector2.new(0, 0.5),
                Position = UDim2.new(0, 10, 0.5, 0),
                Size = UDim2.new(0, 14, 0, 14),
                ImageColor3 = Scheme.SubFontColor,
                ZIndex = 52,
            })
            applyIcon(searchIcon, "search", 48)
            register(searchIcon, "ImageColor3", "SubFontColor")
            local tb = Instance.new("TextBox")
            tb.BackgroundTransparency = 1
            tb.PlaceholderText = "Search..."
            tb.PlaceholderColor3 = Scheme.DimColor
            tb.TextColor3 = Scheme.FontColor
            tb.TextSize = 13
            tb.Font = Enum.Font.Gotham
            tb.TextXAlignment = Enum.TextXAlignment.Left
            tb.ClearTextOnFocus = false
            tb.Text = ""
            tb.Position = UDim2.new(0, 30, 0, 0)
            tb.Size = UDim2.new(1, -36, 1, 0)
            tb.ZIndex = 52
            tb.Parent = box
            register(tb, "TextColor3", "FontColor")
            searchBox = tb
            tb:GetPropertyChangedSignal("Text"):Connect(function()
                searchText = string.lower(tb.Text or "")
                for v, ent in pairs(popupRows) do
                    local match = searchText == "" or string.find(string.lower(v), searchText, 1, true)
                    ent.frame.Visible = match and true or false
                end
            end)
        end

        popupRows = {}
        for i, v in ipairs(values) do
            local entry = newFrame("Opt_" .. tostring(i), list, {
                Size = UDim2.new(1, -4, 0, rowH),
                BackgroundColor3 = Scheme.ElementColor,
                BackgroundTransparency = 0.6,
                ZIndex = 51,
            })
            corner(entry, 5)
            padding(entry, { l = 8, r = 8 })
            local entryBtn = newButton(entry, {
                Size = UDim2.new(1, 0, 1, 0),
                BackgroundTransparency = 1,
                Text = "",
            })
            entryBtn.ZIndex = 52
            local optLbl = newLabel(entry, v, 12, Scheme.SubFontColor,
                Enum.Font.GothamMedium, Enum.TextXAlignment.Left)
            optLbl.ZIndex = 52
            optLbl.Size = UDim2.new(1, -22, 1, 0)
            -- Selected marker on right ( accent dot )
            local mark = newFrame("Mark", entry, {
                AnchorPoint = Vector2.new(1, 0.5),
                Position = UDim2.new(1, 0, 0.5, 0),
                Size = UDim2.new(0, 8, 0, 8),
                BackgroundColor3 = Scheme.AccentColor,
                BackgroundTransparency = 1,
                ZIndex = 52,
            })
            corner(mark, 4)
            register(mark, "BackgroundColor3", "AccentColor")

            local function refreshSelectedVisual()
                local on
                if multi then on = obj.Value[v] == true
                else on = obj.Value == v end
                tween(optLbl, TI_FAST, { TextColor3 = on and Scheme.FontColor or Scheme.SubFontColor })
                tween(mark,   TI_FAST, { BackgroundTransparency = on and 0 or 1 })
                tween(entry,  TI_FAST, { BackgroundTransparency = on and 0.3 or 0.6 })
            end
            refreshSelectedVisual()

            entryBtn.MouseEnter:Connect(function()
                tween(entry, TI_FAST, { BackgroundColor3 = Scheme.HoverColor })
            end)
            entryBtn.MouseLeave:Connect(function()
                tween(entry, TI_FAST, { BackgroundColor3 = Scheme.ElementColor })
            end)
            entryBtn.MouseButton1Click:Connect(function()
                if multi then
                    obj.Value[v] = not obj.Value[v] or nil
                    if obj.Value[v] == false then obj.Value[v] = nil end
                    refreshSelectedVisual()
                    refreshValueLabel()
                    for _, cb in ipairs(obj._changed) do pcall(cb, obj.Value) end
                    if callback then pcall(callback, obj.Value) end
                else
                    obj.Value = v
                    for kk, ent in pairs(popupRows) do ent.refresh() end
                    refreshValueLabel()
                    for _, cb in ipairs(obj._changed) do pcall(cb, obj.Value) end
                    if callback then pcall(callback, obj.Value) end
                    destroyPopup()
                end
            end)

            popupRows[v] = { frame = entry, refresh = refreshSelectedVisual }
        end

        -- Slide-in animation
        popup.Size = UDim2.fromOffset(rowSz.X, 0)
        tween(popup, TI_MED, { Size = UDim2.fromOffset(rowSz.X, totalH) })
        tween(chev, TI_FAST, { Rotation = 180 })

        popupHandle.frame = popup
        setActivePopup(popupHandle)
    end

    btn.MouseButton1Click:Connect(function()
        if popup then destroyPopup() else buildPopup() end
    end)

    bindHover(row, "BackgroundColor3", "ElementColor", "HoverColor")

    function obj:SetValue(v)
        if multi then
            obj.Value = normaliseDefault(v)
        else
            obj.Value = v
        end
        refreshValueLabel()
        if popupRows then
            for _, e in pairs(popupRows) do e.refresh() end
        end
        for _, cb in ipairs(self._changed) do pcall(cb, obj.Value) end
        if callback then pcall(callback, obj.Value) end
    end

    function obj:SetValues(newValues)
        values = newValues or {}
        obj.Values = values
        if popup then destroyPopup() end
    end

    function obj:OnChanged(cb)
        if type(cb) == "function" then
            table.insert(self._changed, cb)
            pcall(cb, self.Value)
        end
        return self
    end

    if type(opts.Tooltip) == "string" and opts.Tooltip ~= "" then
        Library:BindTooltip(row, opts.Tooltip)
    end

    Library.Options[idx] = obj
    return obj
end

-- ============================================================
--  INPUT FACTORY ( single-line text field )
--  opts = { Text, Default, Placeholder, Numeric, MaxLength, Callback }
-- ============================================================
local function buildInput(parent, idx, opts)
    opts = opts or {}
    local text        = opts.Text or idx
    local default     = opts.Default or ""
    local placeholder = opts.Placeholder or ""
    local numeric     = opts.Numeric == true
    local maxLen      = opts.MaxLength
    local callback    = opts.Callback

    local row = newFrame("Input_" .. tostring(idx), parent, {
        Size = UDim2.new(1, 0, 0, 36),
        BackgroundColor3 = Scheme.ElementColor,
        BackgroundTransparency = 0,
    })
    register(row, "BackgroundColor3", "ElementColor")
    corner(row, 7)
    local rowStroke = stroke(row, Scheme.OutlineColor, 1, 0.7)
    register(rowStroke, "Color", "OutlineColor")
    padding(row, { l = 12, r = 10 })

    local lbl = newLabel(row, text, 13, Scheme.FontColor,
        Enum.Font.GothamMedium, Enum.TextXAlignment.Left)
    lbl.Size = UDim2.new(0.4, 0, 1, 0)
    register(lbl, "TextColor3", "FontColor")

    local field = newFrame("Field", row, {
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, 0, 0.5, 0),
        Size = UDim2.new(0.6, -8, 0, 24),
        BackgroundColor3 = Scheme.BackgroundColor,
        BackgroundTransparency = 0.3,
    })
    register(field, "BackgroundColor3", "BackgroundColor")
    corner(field, 5)
    padding(field, { l = 8, r = 8 })

    local tb = Instance.new("TextBox")
    tb.BackgroundTransparency = 1
    tb.Text = tostring(default)
    tb.PlaceholderText = placeholder
    tb.PlaceholderColor3 = Scheme.DimColor
    tb.TextColor3 = Scheme.FontColor
    tb.TextSize = 12
    tb.Font = Enum.Font.Gotham
    tb.TextXAlignment = Enum.TextXAlignment.Left
    tb.ClearTextOnFocus = false
    tb.Size = UDim2.new(1, 0, 1, 0)
    tb.Parent = field
    register(tb, "TextColor3", "FontColor")

    local obj = { Value = tostring(default), _changed = {}, _idx = idx }

    local function commit(s)
        if numeric then
            s = (s or ""):gsub("[^%-%d%.]", "")
        end
        if maxLen then s = s:sub(1, maxLen) end
        if s ~= obj.Value then
            obj.Value = s
            for _, cb in ipairs(obj._changed) do pcall(cb, s) end
            if callback then pcall(callback, s) end
        end
        if tb.Text ~= s then tb.Text = s end
    end

    tb.FocusLost:Connect(function() commit(tb.Text) end)
    tb:GetPropertyChangedSignal("Text"):Connect(function()
        if maxLen and #tb.Text > maxLen then
            tb.Text = tb.Text:sub(1, maxLen)
        end
    end)

    function obj:SetValue(v) commit(tostring(v or "")) end
    function obj:OnChanged(cb)
        if type(cb) == "function" then
            table.insert(self._changed, cb)
            pcall(cb, self.Value)
        end
        return self
    end

    if type(opts.Tooltip) == "string" and opts.Tooltip ~= "" then
        Library:BindTooltip(row, opts.Tooltip)
    end

    Library.Options[idx] = obj
    return obj
end

-- Wire factories into the lazy-loaded slots used by groupbox.
Library._BuildDropdown = buildDropdown
Library._BuildInput    = buildInput

