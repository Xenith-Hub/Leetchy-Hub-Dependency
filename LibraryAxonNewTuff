-- Hover state helper. Wires MouseEnter / MouseLeave to a
-- TweenService colour swap on the supplied instance. Returns
-- a handle with :Disconnect() so unloading is clean.
local function bindHover(target, propName, baseKey, hoverKey)
    local conns = {}
    table.insert(conns, target.MouseEnter:Connect(function()
        tween(target, TI_FAST, { [propName] = Scheme[hoverKey] })
    end))
    table.insert(conns, target.MouseLeave:Connect(function()
        tween(target, TI_FAST, { [propName] = Scheme[baseKey] })
    end))
    return {
        Disconnect = function()
            for _, c in ipairs(conns) do c:Disconnect() end
        end
    }
end

-- ============================================================
--  DRAGGABLE — generic drag handler bound to a "handle" Instance
--  ( typically the topbar ) that translates input deltas into
--  Position changes on a "frame" ( the window root ). Mirrors
--  Obsidian's behaviour : drag locks at screen edges, clamping
--  is left to the caller.
-- ============================================================
local function makeDraggable(handle, frame)
    local dragging, dragStart, startPos
    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            dragging  = true
            dragStart = input.Position
            startPos  = frame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if not dragging then return end
        if input.UserInputType == Enum.UserInputType.MouseMovement
        or input.UserInputType == Enum.UserInputType.Touch then
            local d = input.Position - dragStart
            frame.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + d.X,
                startPos.Y.Scale, startPos.Y.Offset + d.Y
            )
        end
    end)
end

