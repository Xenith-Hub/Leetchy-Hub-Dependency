function ThemeManager:SetLibrary(lib) self._lib = lib end
function ThemeManager:SetFolder(folder) self._folder = folder end

function ThemeManager:ApplyPreset(name)
    local p = self._presets[name]
    if not p then return end
    for k, v in pairs(p) do
        if Scheme[k] ~= nil then Scheme[k] = v end
    end
    pcall(function() self._lib:UpdateColorsUsingRegistry() end)
end

-- Curated display order — keep the neutral default first, then
-- bright accents from cool to warm so the dropdown reads as a
-- moodboard rather than an alphabetical dump.
local THEME_ORDER = { "Onyx", "Midnight", "Emerald", "Crimson", "Violet" }

function ThemeManager:ApplyToTab(tab)
    if not tab or not tab.AddLeftGroupbox then return end
    local gb = tab:AddLeftGroupbox("Theme")
    local presetNames = {}
    local seen = {}
    for _, name in ipairs(THEME_ORDER) do
        if self._presets[name] then
            table.insert(presetNames, name)
            seen[name] = true
        end
    end
    -- Append any extra presets users may have registered.
    for k in pairs(self._presets) do
        if not seen[k] then table.insert(presetNames, k) end
    end
    gb:AddDropdown("ThemePreset", {
        Text     = "Preset",
        Values   = presetNames,
        Default  = presetNames[1] or "Onyx",
        Multi    = false,
        Tooltip  = "Re-skin chaque élément de l'UI ( fond, accents, texte ) en direct.",
        Callback = function(v) ThemeManager:ApplyPreset(v) end,
    })
    gb:AddLabel("Switch presets to re-skin the entire UI live.", true)
end

Library.ThemeManager = ThemeManager

-- ============================================================
--  SAVE MANAGER  ( minimal, drop-in compatible )
--  Persists Toggles / Options to executor disk via writefile /
--  readfile when available. Provides BuildConfigSection that
--  spawns a Configurations groupbox in any tab. If the executor
--  lacks file IO ( e.g. studio ), all calls degrade to no-ops.
-- ============================================================
local SaveManager = {
    _lib            = Library,
    _folder         = "ArvynLib",
    _ignoreTheme    = false,
    _ignoreIndexes  = {},
    _autoload       = nil,
}

local function fsEnabled()
    return type(writefile) == "function"
       and type(readfile)  == "function"
       and type(isfile)    == "function"
       and type(makefolder)== "function"
       and type(isfolder)  == "function"
end

local function ensureFolder(path)
    if not fsEnabled() then return false end
    if not isfolder(path) then pcall(makefolder, path) end
    return isfolder(path)
end

function SaveManager:SetLibrary(lib) self._lib = lib end
function SaveManager:SetFolder(folder)
    self._folder = folder
    if fsEnabled() then
        local parts = {}
        for p in folder:gmatch("[^/]+") do
            table.insert(parts, p)
            ensureFolder(table.concat(parts, "/"))
        end
        ensureFolder(folder .. "/configs")
    end
end
function SaveManager:IgnoreThemeSettings() self._ignoreTheme = true end
function SaveManager:SetIgnoreIndexes(t)
    self._ignoreIndexes = {}
    for _, k in ipairs(t or {}) do self._ignoreIndexes[k] = true end
end
function SaveManager:SetSubFolder(s) self._sub = s end

local function jsonEncode(t)
    local ok, s = pcall(function()
        return game:GetService("HttpService"):JSONEncode(t)
    end)
    return ok and s or "{}"
end
local function jsonDecode(s)
    local ok, t = pcall(function()
        return game:GetService("HttpService"):JSONDecode(s or "{}")
    end)
    return ok and t or {}
end

function SaveManager:_serialise()
    local t = { toggles = {}, options = {} }
    for k, o in pairs(self._lib.Toggles) do
        if not self._ignoreIndexes[k] then
            t.toggles[k] = o.Value and true or false
        end
    end
    for k, o in pairs(self._lib.Options) do
        if not self._ignoreIndexes[k] then
            t.options[k] = o.Value
        end
    end
    return t
end

function SaveManager:_apply(data)
    if type(data) ~= "table" then return end
    if data.toggles then
        for k, v in pairs(data.toggles) do
            local o = self._lib.Toggles[k]
            if o and o.SetValue then pcall(o.SetValue, o, v) end
        end
    end
    if data.options then
        for k, v in pairs(data.options) do
            local o = self._lib.Options[k]
            if o and o.SetValue then pcall(o.SetValue, o, v) end
        end
    end
end

function SaveManager:Save(name)
    if not fsEnabled() then return false, "no fs" end
    name = (name or "default"):gsub("[^%w%-_]", "_")
    local path = self._folder .. "/configs/" .. name .. ".json"
    local ok, err = pcall(writefile, path, jsonEncode(self:_serialise()))
    return ok, err
end

function SaveManager:Load(name)
    if not fsEnabled() then return false, "no fs" end
    name = (name or "default"):gsub("[^%w%-_]", "_")
    local path = self._folder .. "/configs/" .. name .. ".json"
    if not isfile(path) then return false, "missing" end
    local ok, body = pcall(readfile, path)
    if not ok then return false, body end
    self:_apply(jsonDecode(body))
    -- Sync the topbar config label so the read-only indicator
    -- always shows the active config name.
    if self._lib and self._lib._cfgLbl then
        pcall(function() self._lib._cfgLbl.Text = name end)
    end
    self._current = name
    return true
end

function SaveManager:ListConfigs()
    local out = { "default" }
    if fsEnabled() and isfolder(self._folder .. "/configs") then
        local ok, files = pcall(listfiles, self._folder .. "/configs")
        if ok and files then
            local seen = { default = true }
            for _, f in ipairs(files) do
                local n = f:match("([^/\\]+)%.json$")
                if n and not seen[n] then
                    table.insert(out, n)
                    seen[n] = true
                end
            end
        end
    end
    return out
end

function SaveManager:LoadAutoloadConfig()
    if not fsEnabled() then return end
    local apath = self._folder .. "/autoload.txt"
    if isfile(apath) then
        local ok, name = pcall(readfile, apath)
        if ok and name and #name > 0 then
            self._autoload = name
            self:Load(name)
        end
    end
end

function SaveManager:BuildConfigSection(tab)
    if not tab or not tab.AddLeftGroupbox then return end
    local gb = tab:AddRightGroupbox("Configurations")

    local nameInput = gb:AddInput("ConfigName", {
        Text        = "Name",
        Placeholder = "default",
        Default     = "default",
        MaxLength   = 32,
    })

    local listOpt
    local function listConfigs()
        local out = { "default" }
        if fsEnabled() and isfolder(self._folder .. "/configs") then
            local ok, files = pcall(listfiles, self._folder .. "/configs")
            if ok and files then
                local seen = { default = true }
                for _, f in ipairs(files) do
                    local n = f:match("([^/\\]+)%.json$")
                    if n and not seen[n] then
                        table.insert(out, n)
                        seen[n] = true
                    end
                end
            end
        end
        return out
    end

    listOpt = gb:AddDropdown("ConfigList", {
        Text     = "Config",
        Values   = listConfigs(),
        Default  = "default",
        Multi    = false,
    })

    gb:AddButton("Save", function()
        local n = nameInput.Value
        local ok, err = self:Save(n)
        if ok then
            Library:Notify("Saved config '" .. tostring(n) .. "'", 3)
            listOpt:SetValues(listConfigs())
        else
            Library:Notify("Save failed: " .. tostring(err), 4)
        end
    end)

    gb:AddButton("Overwrite Config", function()
        local n = listOpt.Value or "default"
        local ok, err = self:Save(n)
        if ok then
            Library:Notify("Overwrote '" .. tostring(n) .. "'", 3)
        else
            Library:Notify("Overwrite failed: " .. tostring(err), 4)
        end
    end)

    gb:AddButton("Load", function()
        local n = listOpt.Value
        local ok, err = self:Load(n)
        if ok then
            Library:Notify("Loaded config '" .. tostring(n) .. "'", 3)
        else
            Library:Notify("Load failed: " .. tostring(err), 4)
        end
    end)

    gb:AddButton("Set Autoload", function()
        if not fsEnabled() then
            Library:Notify("No filesystem support", 3)
            return
        end
        pcall(writefile, self._folder .. "/autoload.txt", listOpt.Value or "default")
        Library:Notify("Autoload set to '" .. tostring(listOpt.Value) .. "'", 3)
    end)

    gb:AddButton("Reset Autoload", function()
        if not fsEnabled() then
            Library:Notify("No filesystem support", 3)
            return
        end
        local apath = self._folder .. "/autoload.txt"
        if isfile(apath) then
            local ok = pcall(delfile, apath)
            if ok then
                self._autoload = nil
                Library:Notify("Autoload cleared", 3)
            else
                Library:Notify("Could not clear autoload", 3)
            end
        else
            Library:Notify("No autoload set", 2)
        end
    end)

    gb:AddButton("Refresh List", function()
        listOpt:SetValues(listConfigs())
        Library:Notify("Config list refreshed", 2)
    end)
end

Library.SaveManager = SaveManager

-- ============================================================
--  Public exports
-- ============================================================
return Library
